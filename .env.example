account=anvil
chain=anvil

# Optional. Owner of the deployed MatchweekFactory. Defaults to the deployer address if unset.
ADMIN=ADMIN_ADDRESS

# RPC URL used by the "hyperevm_testnet" entry in foundry.toml's [rpc_endpoints].
# Set chain=hyperevm_testnet and account=<your keystore account> to deploy there.
# Testnet chain ID: 998
HYPEREVM_TESTNET_RPC_URL=https://rpc.url
